---
creation_rules:
  - path_regex: talos/.*\.sops\.ya?ml
    mac_only_encrypted: true
    age: "#{ age_key('public') }#"
  - path_regex: (bootstrap|kubernetes/secret)/.*\.sops\.ya?ml
    encrypted_regex: "^(data|stringData)$"
    mac_only_encrypted: true
    age: "#{ age_key('public') }#"
  - path_regex: kubernetes/apps/kube-system/ceph-csi/.*\.sops\.ya?ml
    encrypted_regex: "^(adminKey|userKey|.*Key)$"
    mac_only_encrypted: true
    age: "#{ age_key('public') }#"
  - path_regex: kubernetes/.*\.sops\.ya?ml
    encrypted_regex: "^(data|stringData)$"
    mac_only_encrypted: true
    age: "#{ age_key('public') }#"
stores:
  yaml:
    indent: 2
