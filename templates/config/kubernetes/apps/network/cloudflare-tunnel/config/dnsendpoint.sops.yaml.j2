---
apiVersion: externaldns.k8s.io/v1alpha1
kind: DNSEndpoint
metadata:
  name: cloudflare-tunnel
spec:
  endpoints:
    - dnsName: "external.#{ cloudflare_domain }#"
      recordType: CNAME
      targets: ["#{ cloudflare_tunnel_id() }#.cfargotunnel.com"]
    - dnsName: "nginx-test.#{ cloudflare_domain }#"
      recordType: CNAME
      targets: ["#{ cloudflare_tunnel_id() }#.cfargotunnel.com"]
    - dnsName: "grafana.#{ cloudflare_domain }#"
      recordType: CNAME
      targets: ["external.#{ cloudflare_domain }#"]
