---
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: ceph-csi
  namespace: argo-system
  annotations:
    argocd.argoproj.io/sync-wave: '0'
spec:
  project: kubernetes
  sources:
    - repoURL: "https://github.com/#{ repository_name }#.git"
      path: kubernetes/apps/storage/ceph-csi
      targetRevision: #{ repository_branch }#
      ref: repo
    - repoURL: https://ceph.github.io/csi-charts
      chart: ceph-csi-cephfs
      targetRevision: v3.12.3
      helm:
        releaseName: ceph-csi
        valueFiles:
          - $repo/kubernetes/apps/storage/ceph-csi/values.sops.yaml
  destination:
    name: in-cluster
    namespace: storage
  syncPolicy:
    automated:
      allowEmpty: true
      prune: true
      selfHeal: true
    retry:
      limit: 1
      backoff:
        duration: 10s
        factor: 2
        maxDuration: 3m
    syncOptions:
      - CreateNamespace=true
      - ApplyOutOfSyncOnly=true
      - ServerSideApply=true
      - PruneLast=true
      - RespectIgnoreDifferences=true
